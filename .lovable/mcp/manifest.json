            },
            "style_overrides": {
              "type": "object",
              "additionalProperties": {},
              "description": "Merge raso com o style_overrides atual."
            },
            "prompt_hints": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 20000
                },
                {
                  "type": "null"
                }
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 60
              },
              "maxItems": 30
            },
            "scope": {
              "type": "string",
              "enum": [
                "pessoal",
