              "maxLength": 255
            },
            "area": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "piece_type": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "description": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 2000
                },
                {
                  "type": "null"
                }
              ]
            },
            "content_md": {
              "type": "string",
              "maxLength": 200000
            },
            "structure": {
              "type": "object",
              "additionalProperties": {},
