# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env com valores reais.

# URL pública do seu projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (publishable) do Supabase
SUPABASE_PUBLISHABLE_KEY=sua-anon-key

# Variáveis expostas ao Vite (frontend)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key
